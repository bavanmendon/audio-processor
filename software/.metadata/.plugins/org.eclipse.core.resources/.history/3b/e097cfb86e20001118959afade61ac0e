#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010

/******************* TEST ******************************/

int main() {
    // Memory to hold the "Next" samples
    int16_t l_next = 0;
    int16_t r_next = 0;

    // Initialize clock state
    int last_clk = IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE);

    while (1) {
        int current_clk = IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE);

        // --- RISING EDGE: 0 -> 1 (Right Channel Finished) ---
        if (current_clk == 1 && last_clk == 0) {

            // 1. OUTPUT FIRST (The result from the PREVIOUS cycle)
            // This happens at the exact start of the hardware window.
            IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, r_next);

            // 2. READ SECOND
            // Grab the fresh Right channel data that just stabilized.
            int16_t r_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

            // 3. PROCESS (Calculate for the NEXT time this edge hits)
            // This math can take its time; it doesn't need to be sent yet.
            r_next = r_in;
        }

        // --- FALLING EDGE: 1 -> 0 (Left Channel Finished) ---
        else if (current_clk == 0 && last_clk == 1) {

            // 1. OUTPUT FIRST
            IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, l_next);

            // 2. READ SECOND
            int16_t l_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);

            // 3. PROCESS
            l_next = l_in;
        }

        // Update state
        last_clk = current_clk;
    }

    return 0;
}

