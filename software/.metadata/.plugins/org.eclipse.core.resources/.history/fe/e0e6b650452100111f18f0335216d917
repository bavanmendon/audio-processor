#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010


/*********************** TEST ********************************/

int main()
{
    // 1. FIXED-POINT ALPHA (Scaled by 256)
    // alpha = 217 gives a smooth, standard crossover frequency.
    int32_t alpha = 217;
    int32_t inv_alpha = 39;

    // 2. THE 3 EQ STAGES (Scaled by 256)
    // Switch State 0 (00): CUT    (0.5x volume  -> 128)
    // Switch State 1 (01): FLAT   (1.0x volume  -> 256)
    // Switch State 2 (10): BOOST  (2.0x volume  -> 512)
    // Switch State 3 (11): BOOST+ (2.5x volume  -> 640) <- Fallback if both switches are UP
    int32_t multipliers[4] = {128, 256, 512, 640};

    // State variables for the IIR filter (must persist between loops)
    int32_t l_bass_prev = 0;
    int32_t r_bass_prev = 0;

    printf("3-Stage IIR Audio Crossover Running...\n");

    while(1)
    {
        // 3. Wait for the new audio sample flag (Rising Edge)
        if(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1)
        {
            // Read switches (yields 0, 1, 2, or 3)
            int b_stage = IORD_ALTERA_AVALON_PIO_DATA(BASSSTAGESWITCH_BASE) & 0x03;
            int t_stage = IORD_ALTERA_AVALON_PIO_DATA(TREBLESTAGESWITCH_BASE) & 0x03;

            // Read raw data directly into 32-bit integers to prevent overflow
            int32_t l_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
            int32_t r_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

            // --- THE CROSSOVER ---
            // Bass (Low-Pass): y[n] = (alpha * y[n-1] + inv_alpha * x[n]) / 256
            int32_t l_bass = ((alpha * l_bass_prev) + (inv_alpha * l_in)) >> 8;
            int32_t r_bass = ((alpha * r_bass_prev) + (inv_alpha * r_in)) >> 8;

            // Treble (High-Pass): Input - Bass
            int32_t l_treble = l_in - l_bass;
            int32_t r_treble = r_in - r_bass;

            // Save the bass state for the next audio frame
            l_bass_prev = l_bass;
            r_bass_prev = r_bass;

            // --- THE MIXER ---
            // Apply the chosen multiplier stage, then shift down to scale back to normal
            int32_t l_out = ((l_bass * multipliers[b_stage]) + (l_treble * multipliers[t_stage])) >> 8;
            int32_t r_out = ((r_bass * multipliers[b_stage]) + (r_treble * multipliers[t_stage])) >> 8;

            // --- FAST LIMITER (Anti-Clipping) ---
            // Prevents integer overflow wrap-around (which sounds like violent static)
            if(l_out > 32767) l_out = 32767;
            else if(l_out < -32768) l_out = -32768;

            if(r_out > 32767) r_out = 32767;
            else if(r_out < -32768) r_out = -32768;

            // 4. Send the mixed and limited audio to the DAC
            IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, (int16_t)l_out);
            IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, (int16_t)r_out);

            // 5. Wait for the hardware flag to drop before looping
            while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1) { }
        }
    }
    return 0;
}

