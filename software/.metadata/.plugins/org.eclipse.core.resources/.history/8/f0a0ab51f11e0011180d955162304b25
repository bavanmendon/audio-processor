#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010

/******************* TEST ******************************/

int main()
{
	// 1. Smooth low-pass crossover alpha (approx 1kHz cutoff at 48kHz)
	float alpha = 0.85f;

	// 2. Volume Multipliers for Switch States
	// 0=Mute, 1=Half, 2=Normal, 3=Double (Boost)
	float multipliers[4] = {0.0f, 0.5f, 1.0f, 2.0f};

	static float l_bass_prev = 0.0f;
	static float r_bass_prev = 0.0f;

	while(1)
	{
		// 3. THE HARD WAIT: Lock the CPU perfectly to the hardware clock
		while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 0) { }

		// Read the switches
		int b_stage = IORD_ALTERA_AVALON_PIO_DATA(BASSSTAGESWITCH_BASE) & 0x03;
		int t_stage = IORD_ALTERA_AVALON_PIO_DATA(TREBLESTAGESWITCH_BASE) & 0x03;

		// Read raw audio data
		int16_t l_data = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
		int16_t r_data = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

		float l_in = (float)l_data;
		float r_in = (float)r_data;

		// --- THE DSP CROSSOVER EQ (IIR Filter) ---
		float l_bass = (alpha * l_bass_prev) + ((1.0f - alpha) * l_in);
		float r_bass = (alpha * r_bass_prev) + ((1.0f - alpha) * r_in);

		// --- ANTI-DENORMAL: Snap to zero if silent to stop pause-buzz ---
		if(l_bass > -0.1f && l_bass < 0.1f) l_bass = 0.0f;
		if(r_bass > -0.1f && r_bass < 0.1f) r_bass = 0.0f;

		// Extract the Treble
		float l_treble = l_in - l_bass;
		float r_treble = r_in - r_bass;

		// Apply the volume multipliers
		float l_out_float = (l_bass * multipliers[b_stage]) + (l_treble * multipliers[t_stage]);
		float r_out_float = (r_bass * multipliers[b_stage]) + (r_treble * multipliers[t_stage]);

		// Save the bass state for the next loop
		l_bass_prev = l_bass;
		r_bass_prev = r_bass;

		// --- THE HARD LIMITER: Prevents wrap-around distortion ---
		if(l_out_float > 32767.0f) l_out_float = 32767.0f;
		else if(l_out_float < -32768.0f) l_out_float = -32768.0f;

		if(r_out_float > 32767.0f) r_out_float = 32767.0f;
		else if(r_out_float < -32768.0f) r_out_float = -32768.0f;

		// Cast back to 16-bit integers safely
		int16_t l_out = (int16_t)l_out_float;
		int16_t r_out = (int16_t)r_out_float;

		// 4. Send to speakers
		IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, l_out);
		IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, r_out);

		// 5. Wait for the hardware flag to finish
		while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1) { }
	}
	return 0;
}

