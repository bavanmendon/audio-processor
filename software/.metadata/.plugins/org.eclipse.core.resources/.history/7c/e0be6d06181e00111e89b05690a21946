#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010

#include "system.h"
#include "altera_avalon_pio_regs.h"
#include <stdint.h>

/************************Cleaner*************************/

int main()
{
	// History variables for the Low-Pass Filter
	static int32_t l_bass_accum = 0;
	static int32_t r_bass_accum = 0;

	while(1)
	{
		// 1. Read switches (0 = Mute, 1 = Half, 2 = Normal, 3 = Double)
		int b_stage = IORD_ALTERA_AVALON_PIO_DATA(BASSSTAGESWITCH_BASE) & 0x03;
		int t_stage = IORD_ALTERA_AVALON_PIO_DATA(TREBLESTAGESWITCH_BASE) & 0x03;

		// 2. Wait for new audio
		if(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1)
		{
			// Read raw 16-bit data and preserve sign
			int32_t l_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
			int32_t r_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

			// --- DSP FILTERING (Noisy Truncation FIXED!) ---
			// Formula: y[n] = y[n-1] + (x[n] - y[n-1]) / 8
			// This creates a smooth Low-Pass filter without dropping detail bits!

			l_bass_accum += (l_in - l_bass_accum) >> 3;
			r_bass_accum += (r_in - r_bass_accum) >> 3;

			int32_t l_bass = l_bass_accum;
			int32_t r_bass = r_bass_accum;

			// High-Pass (Treble) is just the original signal minus the bass
			int32_t l_treble = l_in - l_bass;
			int32_t r_treble = r_in - r_bass;

			// --- VOLUME MULTIPLIERS (Clean Bit-Shifting) ---
			// Apply the switch settings cleanly using bit-shifts

			// Bass volume control
			if (b_stage == 0)      l_bass = 0;           // Muted
			else if (b_stage == 1) l_bass = l_bass >> 1; // Half volume
			else if (b_stage == 3) l_bass = l_bass << 1; // Double volume

			if (b_stage == 0)      r_bass = 0;
			else if (b_stage == 1) r_bass = r_bass >> 1;
			else if (b_stage == 3) r_bass = r_bass << 1;

			// Treble volume control
			if (t_stage == 0)      l_treble = 0;           // Muted
			else if (t_stage == 1) l_treble = l_treble >> 1; // Half volume
			else if (t_stage == 3) l_treble = l_treble << 1; // Double volume

			if (t_stage == 0)      r_treble = 0;
			else if (t_stage == 1) r_treble = r_treble >> 1;
			else if (t_stage == 3) r_treble = r_treble << 1;

			// --- RECOMBINE & ANTI-CLIPPING ---
			int32_t l_out = l_bass + l_treble;
			int32_t r_out = r_bass + r_treble;

			// Hard Limiter: Prevent integer overflow screeching!
			if(l_out > 32767) l_out = 32767;
			if(l_out < -32768) l_out = -32768;
			if(r_out > 32767) r_out = 32767;
			if(r_out < -32768) r_out = -32768;

			// 3. Write clean, limited 16-bit audio to DAC
			IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, (int16_t)l_out);
			IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, (int16_t)r_out);

			// 4. Wait for flag to drop
			while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1) { }
		}
	}
	return 0;
}

