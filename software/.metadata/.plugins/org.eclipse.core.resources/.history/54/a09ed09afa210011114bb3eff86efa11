#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010


/*********************** TEST ********************************/

int main() {
    uint8_t current_ready = 0;
    uint8_t last_ready = 0;

    while (1) {
        // Read the live state of the Word Clock
        current_ready = IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE);

        // Trigger exactly once per audio frame (Rising Edge)
        if (current_ready == 1 && last_ready == 0) {

            // 1. Read bare input
            int16_t l_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
//            int16_t r_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

            // 2. Write bare output
            IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, l_in);
            IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, l_in);
        }

        // Save the state to wait for the next frame
        last_ready = current_ready;
    }

    return 0;
}

