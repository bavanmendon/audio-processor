#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010

/******************* TEST ******************************/

int main()
{
	// 1. Volume Multipliers
	float multipliers[4] = {0.0f, 0.5f, 1.0f, 2.0f};

	// 2. THE FIR DELAY LINE (Pure CPU Registers - NO ARRAYS!)
	int32_t l_x0=0, l_x1=0, l_x2=0, l_x3=0, l_x4=0, l_x5=0, l_x6=0, l_x7=0;
	int32_t r_x0=0, r_x1=0, r_x2=0, r_x3=0, r_x4=0, r_x5=0, r_x6=0, r_x7=0;

	while(1)
	{
		// 3. YOUR EXACT WORKING HARDWARE SYNC
		if(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1)
		{
			// Read switches
			int b_stage = IORD_ALTERA_AVALON_PIO_DATA(BASSSTAGESWITCH_BASE) & 0x03;
			int t_stage = IORD_ALTERA_AVALON_PIO_DATA(TREBLESTAGESWITCH_BASE) & 0x03;

			// Read raw audio
			int32_t l_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
			int32_t r_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

			// --- A. SHIFT THE REGISTERS ---
			// This happens entirely inside the CPU core. Zero memory lag.
			l_x7=l_x6; l_x6=l_x5; l_x5=l_x4; l_x4=l_x3; l_x3=l_x2; l_x2=l_x1; l_x1=l_x0; l_x0=l_in;
			r_x7=r_x6; r_x6=r_x5; r_x5=r_x4; r_x4=r_x3; r_x3=r_x2; r_x2=r_x1; r_x1=r_x0; r_x0=r_in;

			// --- B. THE FIR BASS (Moving Average) ---
			// Add them all up and bit-shift by 3 (which divides by 8 instantly)
			int32_t l_bass = (l_x0 + l_x1 + l_x2 + l_x3 + l_x4 + l_x5 + l_x6 + l_x7) >> 3;
			int32_t r_bass = (r_x0 + r_x1 + r_x2 + r_x3 + r_x4 + r_x5 + r_x6 + r_x7) >> 3;

			// --- C. THE FIR TREBLE (Phase-Aligned) ---
			// The center of an 8-tap filter is tap 3.
			int32_t l_treble = l_x3 - l_bass;
			int32_t r_treble = r_x3 - r_bass;

			// --- D. APPLY MULTIPLIERS ---
			// We can safely use float math here since it's only two multiplies!
			float l_out_float = ((float)l_bass * multipliers[b_stage]) + ((float)l_treble * multipliers[t_stage]);
			float r_out_float = ((float)r_bass * multipliers[b_stage]) + ((float)r_treble * multipliers[t_stage]);

			// --- E. THE HARD LIMITER ---
			if(l_out_float > 32767.0f) l_out_float = 32767.0f;
			else if(l_out_float < -32768.0f) l_out_float = -32768.0f;

			if(r_out_float > 32767.0f) r_out_float = 32767.0f;
			else if(r_out_float < -32768.0f) r_out_float = -32768.0f;

			// 4. Send to speakers
			IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, (int16_t)l_out_float);
			IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, (int16_t)r_out_float);

			// 5. Wait for the flag to drop
			while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1) { }
		}
	}
	return 0;
}

