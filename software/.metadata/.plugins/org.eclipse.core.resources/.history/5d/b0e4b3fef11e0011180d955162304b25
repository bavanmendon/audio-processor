#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010

/******************* TEST ******************************/

// 32-Tap FIR Filter (Power of 2 makes bit-shifting easy)
#define FIR_TAPS 32

int main()
{
	// Multipliers: 0=Mute, 128=Half, 256=Normal, 512=Boost
	int32_t multipliers[4] = {0, 128, 256, 512};

	// The Delay Line Buffer
	int32_t l_buffer[FIR_TAPS] = {0};
	int32_t r_buffer[FIR_TAPS] = {0};
	int buffer_idx = 0;

	// The Running Total (This is the magic!)
	int32_t l_sum = 0;
	int32_t r_sum = 0;

	while(1)
	{
		// 1. THE HARD WAIT
		while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 0) { }

		// Read switches
		int b_stage = IORD_ALTERA_AVALON_PIO_DATA(BASSSTAGESWITCH_BASE) & 0x03;
		int t_stage = IORD_ALTERA_AVALON_PIO_DATA(TREBLESTAGESWITCH_BASE) & 0x03;

		// Read new raw audio data
		int32_t l_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
		int32_t r_in = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

		// --- A. Extract the Bass (Zero-Multiply FIR Convolution) ---

		// Step 1: Subtract the oldest sample falling out of the buffer from our total
		l_sum -= l_buffer[buffer_idx];
		r_sum -= r_buffer[buffer_idx];

		// Step 2: Add the brand new sample into our total
		l_sum += l_in;
		r_sum += r_in;

		// Step 3: Overwrite the oldest sample in memory with the new one
		l_buffer[buffer_idx] = l_in;
		r_buffer[buffer_idx] = r_in;

		// Step 4: Advance the clock (& 31 safely wraps it back to 0 when it hits 32)
		buffer_idx = (buffer_idx + 1) & 31;

		// Step 5: Divide the total by 32 to get the average!
		// (Bit-shifting right by 5 is identical to dividing by 32, but takes 1 clock cycle)
		int32_t l_bass = l_sum >> 5;
		int32_t r_bass = r_sum >> 5;

		// --- B. Extract the Treble (Perfect Phase Alignment) ---
		// FIR filters delay audio by exactly half their length. We pull the original
		// audio from exactly 16 samples ago so the Bass and Treble align flawlessly!
		int center_idx = (buffer_idx - 16 + FIR_TAPS) & 31;

		int32_t l_treble = l_buffer[center_idx] - l_bass;
		int32_t r_treble = r_buffer[center_idx] - r_bass;

		// --- C. Apply Multipliers ---
		// Bit-shift Right by 8 (Divides by 256) to scale the volume knobs back down
		int32_t l_out = ((l_bass * multipliers[b_stage]) + (l_treble * multipliers[t_stage])) >> 8;
		int32_t r_out = ((r_bass * multipliers[b_stage]) + (r_treble * multipliers[t_stage])) >> 8;

		// --- D. THE HARD LIMITER ---
		if(l_out > 32767) l_out = 32767;
		else if(l_out < -32768) l_out = -32768;

		if(r_out > 32767) r_out = 32767;
		else if(r_out < -32768) r_out = -32768;

		// 2. Send to speakers
		IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, (int16_t)l_out);
		IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, (int16_t)r_out);

		// 3. Wait for the hardware flag to finish
		while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1) { }
	}
	return 0;
}

