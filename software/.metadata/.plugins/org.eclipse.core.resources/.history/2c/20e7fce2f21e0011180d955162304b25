#define NIOS_DATA_READY_BASE 0x21000
#define NIOS_IN_LEFT_BASE 0x21040
#define NIOS_IN_RIGHT_BASE 0x21030
#define NIOS_OUT_LEFT_BASE 0x21020
#define NIOS_OUT_RIGHT_BASE 0x21010

/******************* TEST ******************************/

// --- BIQUAD COEFFICIENTS (Scaled by 4096 for Integer Math) ---

// 1. Bass Low-Pass Filter (~1kHz Cutoff, Q=0.707)
const int32_t b0_bass = 16;
const int32_t b1_bass = 32;
const int32_t b2_bass = 16;
const int32_t a1_bass = -7435;
const int32_t a2_bass = 3404;

// 2. Treble "Mid Catcher" Low-Pass Filter (~4kHz Cutoff, Q=0.707)
const int32_t b0_mid = 203;
const int32_t b1_mid = 405;
const int32_t b2_mid = 203;
const int32_t a1_mid = -5241;
const int32_t a2_mid = 1956;

int main()
{
	// Multipliers: 0=Mute, 128=Half, 256=Normal, 512=Boost
	int32_t multipliers[4] = {0, 128, 256, 512};

	// --- FILTER MEMORY (History of Inputs and Outputs) ---
	// x = Input history, y = Output history (Left and Right)
	int32_t lx1 = 0, lx2 = 0, rx1 = 0, rx2 = 0; // Shared Input History

	int32_t l_bass_y1 = 0, l_bass_y2 = 0; // Bass Output History
	int32_t r_bass_y1 = 0, r_bass_y2 = 0;

	int32_t l_mid_y1 = 0, l_mid_y2 = 0;   // Mid Catcher Output History
	int32_t r_mid_y1 = 0, r_mid_y2 = 0;

	while(1)
	{
		// 1. THE HARD WAIT
		while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 0) { }

		// Read switches
		int b_stage = IORD_ALTERA_AVALON_PIO_DATA(BASSSTAGESWITCH_BASE) & 0x03;
		int t_stage = IORD_ALTERA_AVALON_PIO_DATA(TREBLESTAGESWITCH_BASE) & 0x03;

		// Read new raw audio data
		int32_t lx0 = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_LEFT_BASE);
		int32_t rx0 = (int16_t)IORD_ALTERA_AVALON_PIO_DATA(NIOS_IN_RIGHT_BASE);

		// --- A. Extract the BASS (Biquad Equation) ---
		// y[n] = (b0*x[n] + b1*x[n-1] + b2*x[n-2] - a1*y[n-1] - a2*y[n-2]) / 4096
		int32_t l_bass = (b0_bass*lx0 + b1_bass*lx1 + b2_bass*lx2 - a1_bass*l_bass_y1 - a2_bass*l_bass_y2) >> 12;
		int32_t r_bass = (b0_bass*rx0 + b1_bass*rx1 + b2_bass*rx2 - a1_bass*r_bass_y1 - a2_bass*r_bass_y2) >> 12;

		// --- B. Extract the TREBLE (Using a 4kHz Mid-Catcher) ---
		int32_t l_mid_catch = (b0_mid*lx0 + b1_mid*lx1 + b2_mid*lx2 - a1_mid*l_mid_y1 - a2_mid*l_mid_y2) >> 12;
		int32_t r_mid_catch = (b0_mid*rx0 + b1_mid*rx1 + b2_mid*rx2 - a1_mid*r_mid_y1 - a2_mid*r_mid_y2) >> 12;

		int32_t l_treble = lx0 - l_mid_catch;
		int32_t r_treble = rx0 - r_mid_catch;

		// --- C. Extract the untouched MIDS ---
		int32_t l_mid = lx0 - l_bass - l_treble;
		int32_t r_mid = rx0 - r_bass - r_treble;

		// --- D. Shift Memory for the next audio frame ---
		lx2 = lx1; lx1 = lx0;
		rx2 = rx1; rx1 = rx0;

		l_bass_y2 = l_bass_y1; l_bass_y1 = l_bass;
		r_bass_y2 = r_bass_y1; r_bass_y1 = r_bass;

		l_mid_y2  = l_mid_y1;  l_mid_y1  = l_mid_catch;
		r_mid_y2  = r_mid_y1;  r_mid_y1  = r_mid_catch;

		// --- E. Apply Volume Multipliers (>> 8 divides by 256) ---
		int32_t l_out = ((l_bass * multipliers[b_stage]) + (l_mid * 256) + (l_treble * multipliers[t_stage])) >> 8;
		int32_t r_out = ((r_bass * multipliers[b_stage]) + (r_mid * 256) + (r_treble * multipliers[t_stage])) >> 8;

		// --- F. THE HARD LIMITER ---
		if(l_out > 32767) l_out = 32767;
		else if(l_out < -32768) l_out = -32768;

		if(r_out > 32767) r_out = 32767;
		else if(r_out < -32768) r_out = -32768;

		// 2. Send to speakers
		IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_LEFT_BASE, (int16_t)l_out);
		IOWR_ALTERA_AVALON_PIO_DATA(NIOS_OUT_RIGHT_BASE, (int16_t)r_out);

		// 3. Wait for the hardware flag to finish
		while(IORD_ALTERA_AVALON_PIO_DATA(NIOS_DATA_READY_BASE) == 1) { }
	}
	return 0;
}

